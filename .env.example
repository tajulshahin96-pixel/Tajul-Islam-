# Mailchimp Credentials
# Get these from your Mailchimp Account -> Account & Billing -> Extras -> API Keys
MAILCHIMP_API_KEY=your_mailchimp_api_key_here

# Get this from Audience -> All Contacts -> Settings -> Audience name and defaults
MAILCHIMP_AUDIENCE_ID=your_audience_id_here

# This is the prefix of your API endpoint (e.g., us21, us1)
MAILCHIMP_DC=usXX

# Server Configuration
PORT=3000
NODE_ENV=development
